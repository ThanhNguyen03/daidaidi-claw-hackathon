# =============================================================================
# Multi-Agent Sales AI Assistant - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials
# See README.md for detailed setup instructions

# =============================================================================
# GreenNode LLM Configuration (MAAS - OpenAI Compatible)
# =============================================================================
# Base URL for GreenNode MAAS API (OpenAI-compatible endpoint)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Your GreenNode API Key (get from https://console.greennode.ai/)
LLM_API_KEY=your_greennode_api_key_here

# =============================================================================
# Per-Agent Model Configuration
# =============================================================================
# Each agent can use a different model - specify the model `path` from GreenNode
# Get available model paths by running: curl -H "Authorization: Bearer $LLM_API_KEY" \
#   "https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1/models" -s | jq '.data[].path'

# Orchestrator (Supervisor) - Uses MiniMax M2.5 for reasoning/agentic tasks
MODEL_ORCHESTRATOR=minimax/minimax-m2.5

# Tech Solution Agent - Uses MiniMax M2.5 for reasoning
MODEL_TECH_SOLUTION=minimax/minimax-m2.5

# Market/Strategy Agent - Uses Qwen 3 for balanced tool-calling
MODEL_MARKET_STRATEGY=qwen/qwen3-5-27b

# Account Agent - Uses Qwen 3 for reliable tool-calling
MODEL_ACCOUNT=qwen/qwen3-5-27b

# AdtimaBox Agent - Uses Qwen 3
MODEL_ADTIMABOX=qwen/qwen3-5-27b

# Design Agent - Uses MiniMax M2.5 for slide generation
MODEL_DESIGN=minimax/minimax-m2.5

# Compliance Agent - Uses Qwen 3 (grounded policy RAG + reliable narration)
MODEL_COMPLIANCE=qwen/qwen3-5-27b

# Content Generator Agent - Uses Qwen 3 for narrative writing
MODEL_CONTENT_GENERATOR=qwen/qwen3-5-27b

# Client Simulator Agent (A9) - Uses MiniMax M2.5 for adversarial reasoning
MODEL_CLIENT_SIMULATOR=minimax/minimax-m2.5

# Validation Pass - Uses MiniMax M2.5 for classification
MODEL_VALIDATION=minimax/minimax-m2.5

# =============================================================================
# AgentBase Platform Configuration (Optional - for managed services)
# =============================================================================
# If you want to use AgentBase managed services instead of local fallbacks.
# Leave these commented out to run on the local SQLite/LanceDB fallbacks.
#
# AUTH MODEL: AgentBase services (Memory, MCP Gateway) authenticate with IAM
# credentials, NOT a per-service API key. The base URLs are FIXED and known by
# the SDK, so you do NOT set a memory "URL" or memory "API key".
#   - Local dev: provide GREENNODE_CLIENT_ID + GREENNODE_CLIENT_SECRET below
#     (or place them in a .greennode.json file the SDK/scripts read).
#   - On AgentBase Runtime: GREENNODE_CLIENT_ID, GREENNODE_CLIENT_SECRET and
#     GREENNODE_AGENT_IDENTITY are AUTO-INJECTED into the container — leave unset.

# --- Shared IAM credentials (used by Memory + MCP Gateway) ---
# Get from https://iam.console.vngcloud.vn (service account client id/secret)
# AUTO-INJECTED on AgentBase Runtime — only set these for LOCAL development.
# GREENNODE_CLIENT_ID=your_iam_client_id_here
# GREENNODE_CLIENT_SECRET=your_iam_client_secret_here
# GREENNODE_AGENT_IDENTITY=your_agent_identity_here   # optional; auto-injected on Runtime

# --- AgentBase Memory (optional - SQLite checkpointer fallback if unset) ---
# Base URL is fixed (https://agentbase.api.vngcloud.vn/memory) - do NOT set it here.
# AGENTBASE_MEMORY_ID is the memory you created (e.g. mem_abc123) via:
#   bash .claude/skills/agentbase/scripts/memory.sh create ...   (or the console)
# This is the value that was previously missing — the bridge needs it:
#   AgentBaseMemoryEvents(memory_id=AGENTBASE_MEMORY_ID)
# AGENTBASE_MEMORY_ID=mem_xxxxxxxxxxxx
# MEMORY_STRATEGY_ID is the long-term-memory strategy id inside that memory
# (used by the MemoryClient remember/recall tools - a fixed app-level setting).
# MEMORY_STRATEGY_ID=strat_xxxxxxxxxxxx

# --- AgentBase MCP Gateway (optional - direct MCP client used if not provided) ---
# AGENTBASE_GATEWAY_URL is the endpoint of the gateway you created (it has a real
# per-gateway URL); auth uses the shared IAM credentials above (inbound auth=IAM).
# AGENTBASE_GATEWAY_URL=your_gateway_url_here

# =============================================================================
# Figma Design Output (optional - HTML low-fi fallback used if unset)
# =============================================================================
# Powers the Design agent's Figma DesignBackend. A Personal Access Token (PAT)
# authenticates the Figma REST API. An EDU/education-plan PAT works fine.
#
# CAPABILITIES with a PAT (incl. EDU):
#   - READ files/nodes and EXPORT/RENDER frames to PNG/SVG/PDF  (this is the "output")
#   - Post comments
# NOT POSSIBLE with a PAT (REST has no write-content endpoint):
#   - Creating files or generating new wireframe/frame content from scratch
#     (that needs the Figma Plugin API / use_figma MCP, not a PAT)
#   - Writing local variables (Enterprise plan only; EDU is not Enterprise)
#
# Get a PAT: Figma -> Settings -> Security -> Personal access tokens -> Generate.
# Recommended scopes: files:read (required for export), file_comments:write (optional).
# FIGMA_ACCESS_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxx

# Template file the Design agent reads/exports from (the file "key" in its URL:
# https://www.figma.com/file/<FILE_KEY>/...). Build a wireframe template here once.
# FIGMA_FILE_KEY=your_template_file_key

# =============================================================================
# Application Configuration
# =============================================================================
# Session secret for JWT tokens (generate a random string)
SESSION_SECRET=change_me_in_production

# SQLite database path (for local fallback memory)
SQLITE_DB_PATH=./data/sales_assistant.db

# LanceDB path (local dev only — on AgentBase, HybridKBRepo uses ./data/kb_runtime_cache)
LANCEDB_PATH=./data/knowledge_base

# Server configuration
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable specific features
ENABLE_CHECKPOINT=true
ENABLE_BRAINSTORM=true
ENABLE_AUTO_APPROVE_SESSION=false

# RAG/KB Configuration
KB_EMBEDDING_MODEL=bge-m3
KB_RERANKER_MODEL=bge-reranker-v2-m3

# Debug mode (set to false in production)
DEBUG=true